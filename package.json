  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check-exports": "attw --pack .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "express",
    "api",
    "framework",
    "typescript",
    "rest",
    "middleware",
    "jwt",
    "refresh-token",
    "rate-limit",
    "logging",
    "idempotency",
    "crud",
    "openapi",
    "swagger",
    "joi",
    "validation",
    "graceful-shutdown",
    "scaffold",
    "boilerplate",
    "starter"
  ],
  "dependencies": {
    "cors": "^2.8.5",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "rate-limit-redis": "^5.0.0",
    "winston": "^3.11.0"
  },
  "peerDependencies": {
    "express": "^4.21.0",
    "joi": ">=17"
  },
  "peerDependenciesMeta": {
