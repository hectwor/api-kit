{
  "name": "@hectordahv/api-kit",
  "version": "0.1.0-alpha.2",
  "description": "Opinionated Express + TypeScript API foundation and scaffolder. Standardized response envelope, error handling, JWT auth + stateless refresh tokens, rate limiting, structured logging with correlation IDs, Joi validation, idempotency, graceful shutdown, a generic user-scoped soft-delete CRUD vertical, live auto-generated OpenAPI/Swagger from your Joi schemas, and opt-in modules (activity log, parameter catalog, health checks). Includes a `new` CLI to scaffold a runnable backend.",
  "license": "MIT",
  "author": "hectordahv",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hectwor/api-kit.git"
  },
  "bugs": {
    "url": "https://github.com/hectwor/api-kit/issues"
  },
  "homepage": "https://github.com/hectwor/api-kit#readme",
  "type": "commonjs",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "api-kit": "bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "errors": [
        "./dist/errors/index.d.ts"
      ],
      "http": [
        "./dist/http/index.d.ts"
      ],
      "logging": [
        "./dist/logging/index.d.ts"
      ],
      "middleware": [
        "./dist/middleware/index.d.ts"
      ],
      "validation": [
        "./dist/validation/index.d.ts"
      ],
      "auth": [
        "./dist/auth/index.d.ts"
      ],
      "routes": [
        "./dist/routes/index.d.ts"
      ],
      "config": [
        "./dist/config/index.d.ts"
      ],
      "app": [
        "./dist/app/index.d.ts"
      ],
      "crud": [
        "./dist/crud/index.d.ts"
      ],
      "container": [
        "./dist/container/index.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "openapi": [
        "./dist/openapi/index.d.ts"
      ],
      "testing": [
        "./dist/testing/index.d.ts"
      ],
      "activity-log": [
        "./dist/modules/activity-log/index.d.ts"
      ],
      "parameter-catalog": [
        "./dist/modules/parameter-catalog/index.d.ts"
      ],
      "health": [
        "./dist/modules/health/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.mts",
        "default": "./dist/errors/index.mjs"
      },
      "require": {
        "types": "./dist/errors/index.d.ts",
        "default": "./dist/errors/index.js"
      }
    },
